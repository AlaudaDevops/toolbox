# Environment variables for Roadmap Planner
# Copy this file to .env and update with your values

# Jira Configuration
JIRA_BASE_URL=https://your-jira-instance.atlassian.net
JIRA_USERNAME=your-username
JIRA_PASSWORD=your-api-token
JIRA_PROJECT=DEVOPS

# Server Configuration
SERVER_PORT=8080
DEBUG=false

# Frontend Configuration (for the Vite-built React app)
# Vite substitutes VITE_* vars at build time. Leave empty in production
# when the Go backend serves the frontend on the same origin.
VITE_API_URL=http://localhost:8080
